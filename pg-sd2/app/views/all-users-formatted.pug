extends layout 
block content 
    .main-content
        h1 All Users Formatted Page 
        table(border=1)
            tr 
                th user_id 
                th user_name 
                th bio
                th email 
                th location 
                th Loop Points
                th rating 
                th Joined on

            for user in results 
                tr 
                    td #{user.user_id}
                    td 
                        a(href=`./single-user/${user.user_id}`) #{user.first_name} #{user.last_name}
                    td #{user.bio}
                    td #{user.email} 
                    td #{user.location}
                    td #{user.points}
                    td #{user.average_rating}
                    td #{user.created_at.toLocaleDateString("en-GB", {day:"numeric", month:"short", year:"numeric"})}